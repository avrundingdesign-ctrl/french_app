    "Beliebig oft abspielbar — das ist Training, keine Prüfung.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réécoute autant que tu veux — c'est de l'entraînement, pas un examen."
          }
        }
      }
    },
    "Bestanden — Zertifikat in deiner Galerie": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réussi — certificat dans ta galerie"
